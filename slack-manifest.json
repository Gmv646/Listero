{
  "display_information": {
    "name": "Listero",
    "description": "Your AI financial co-pilot. Real-time purchase pings with one-tap categorization.",
    "background_color": "#1c1917"
  },
  "features": {
    "bot_user": {
      "display_name": "Listero",
      "always_online": true
    }
  },
  "oauth_config": {
    "redirect_urls": [
      "https://app.getlistero.com/api/slack/oauth-callback"
    ],
    "scopes": {
      "bot": [
        "chat:write",
        "chat:write.public",
        "im:write",
        "users:read",
        "commands",
        "im:history"
      ]
    }
  },
  "settings": {
    "interactivity": {
      "is_enabled": true,
      "request_url": "https://app.getlistero.com/api/slack/interactive"
    },
    "org_deploy_enabled": false,
    "socket_mode_enabled": false,
    "token_rotation_enabled": false,
    "event_subscriptions": {
      "request_url": "https://app.getlistero.com/api/slack/events",
      "bot_events": [
        "message.im"
      ]
    }
  }
}